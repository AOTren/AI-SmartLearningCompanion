# ============================================
# AI 期末私教 — 后端环境变量配置
# 复制本文件为 .env 并填入真实值
# 注意：.env 文件请勿提交到 Git 仓库
# ============================================

# ── Coze API 配置 ──

# Coze Personal Access Token (PAT)
# 获取方式：Coze 平台 → 空间设置 → API Token → 新建令牌
COZE_API_KEY=pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.xxxxxxxx

# Coze Bot ID（智能体 ID，纯数字，不加 bot_ 前缀）
# 获取方式：Coze 平台 → 打开你的 Bot → 页面 URL 中的 bot 参数值
# 示例：URL 为 .../bot/7648266478655324196 则填 7648266478655324196
COZE_BOT_ID=7648266478655324196

# Coze API Base URL
# 国内版：https://api.coze.cn
# 国际版：https://api.coze.com
COZE_BASE_URL=https://api.coze.cn

# Coze API 版本路径（通常为 /v3）
COZE_API_VERSION=/v3

# ── 服务配置 ──

# 监听主机（0.0.0.0 允许外部访问）
HOST=0.0.0.0

# 监听端口
PORT=8000

# CORS 允许的来源（逗号分隔，生产环境请收紧）
# 前端开发服务器地址
CORS_ORIGINS=["http://localhost:5500", "http://127.0.0.1:5500", "http://localhost:3000"]

# ── SSE 配置 ──

# SSE 心跳间隔（秒），保持连接活跃
SSE_HEARTBEAT_INTERVAL=15

# 请求 Coze API 的超时时间（秒）
COZE_TIMEOUT=120

# ── 日志配置 ──

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
